# For usage instructions and examples, see:
#   tests/README.md

# Quick start:
#   ./test-iam-api.sh --help

# ============================================
# Keycloak Connection Settings
# ============================================

# Keycloak base URL
# Default: http://localhost:48080
KEYCLOAK_URL=http://localhost:48080

# Keycloak realm name
# Default: imis3
REALM=imis3

# ============================================
# Authentication Credentials
# ============================================

# OAuth2 Client ID
# Default: iam-client
CLIENT_ID=iam-client

# OAuth2 Client Secret
# Default: exampleclientsecret
CLIENT_SECRET=exampleclientsecret

# Test user username
# Default: chefredakteur
USERNAME=chefredakteur

# Test user password
# Default: secret
PASSWORD=secret

# ============================================
# Docker Compose Settings
# ============================================

# Docker Compose file to use
# Default: docker-compose.dev.yml
COMPOSE_FILE=docker-compose.dev.yml

# Docker Compose environment file
# Default: dev.env
COMPOSE_ENV_FILE=dev.env

# ============================================
# Test Settings
# ============================================

# Health check timeout in seconds
# Default: 120
HEALTH_CHECK_TIMEOUT=120

# Verbose output (true/false)
# Default: false
VERBOSE=false

# Disable colored output (true/false)
# Default: false
NO_COLOR=false

# ============================================
# Network Settings (Advanced)
# ============================================

# If running tests from outside Docker network,
# you may need to adjust the KEYCLOAK_URL to match
# your network configuration

# Example for Docker host network:
# KEYCLOAK_URL=http://docker-swa.whale.intevation.de:48080

# Example for remote server:
# KEYCLOAK_URL=https://keycloak.example.com
