# Environment variable values for development setup
REGISTRY_HOST=registry-url.example.test
ABOOK_VERSION=testing
KC_VERSION=testing

PROTOCOLL=http
HOSTNAME=localhost
PORT=48081
HOSTSERVERNAME=${HOSTNAME}:${PORT}
ADMIN_PORT=48080
CLIENT_PATH=/adressbuch/
CLIENT_SECRET=exampleclientsecret
CLIENT_METADATA_URL=http://keycloak:8080/realms/imis3/.well-known/openid-configuration
SESSION_INACTIVITY_TIMEOUT=3600
SESSION_COOKIE_NAME=iam-client-oidc-session
REPORT_MAIL=contact@${HOSTNAME}

#This option allows for a modfied theme in production:
IAM_THEME_SRC=keycloak/iam_theme
