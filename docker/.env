#Notification recipient email address
NOTIFICATION_RECIPIENT=imisnotifications@example.test

#Intervals
# Note: Intervals are expected in ISO-8601 duration format.
# Interval at which accounts are checked for inactivity
MAIL_SCHEDULER_INTERVAL=P1D

# Time after which a notification about inactivity of an account is send to
# $NOTIFICATION_RECIPIENT
ACCOUNT_INACITIVITY_WARNING_TIME=P180D

# Time after which an inactiv account expires
ACCOUNT_EXPIRY_TIME=P365D
