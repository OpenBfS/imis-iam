#Notification recipient email address
NOTIFICATION_RECIPIENT=imisnotifications@example.test

#Intervals
#Note: Intervals are expected in the following format:
#P[numDays]DT[numHours]H[numMinutes]M[numSeconds]S
#Mail scheduler interval
MAIL_SCHEDULER_INTERVAL=PT10S
#Time after an account is considered inactive
ACCOUNT_INACITIVITY_WARNING_TIME=P180D
#TIme after an account expires
ACCOUNT_EXPIRY_TIME=P365D