# Change this to https in productive environment
PROTOCOLL=http

# Change this in productive environment
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=secret

# Base URL for Keycloak
HOSTNAME=localhost
PORT=48080

# ServerName directive for Shibboleth SP in Apache httpd
# SP_HOSTNAME defaults to HOSTNAME
SP_PORT=48081

# Client
CLIENT_HOST=0.0.0.0
# Variable to decide if to start client in development or production mode.
CLIENT_MODE=development

# photon geocoder
PHOTON_URL=https://osm.bfs.de/photon

# Mailhog
MAILHOG_PORT=48082

# Port for external database access
DB_PORT=2345
