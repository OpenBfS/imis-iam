{
  "realm" : "imis3",
  "enabled" : true,
  "resetPasswordAllowed" : true,
  "roles" : {
    "client" : {
      "iam-client" : [ {
        "name" : "user",
        "description" : "roleIamUser",
        "composite" : false
      }, {
        "name" : "editor",
        "description" : "roleIamEditor",
        "composite" : true,
        "composites" : {
          "client" : {
            "iam-client" : [ "user" ]
          }
        }
      }, {
        "name" : "chief_editor",
        "description" : "roleIamChiefEditor",
        "composite" : true,
        "composites" : {
          "client" : {
            "iam-client" : [ "editor" ]
          }
        }
      } ]
    }
  },
  "localizationTexts": {
    "de": {
      "profile.attributes.fax": "Fax",
      "profile.attributes.position": "Position",
      "profile.attributes.tags": "Tags",
      "profile.attributes.network": "Netzbetreiber",
