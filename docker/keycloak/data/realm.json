      "profile.attributes.firstName": "Vorname"
    }
  },
  "clients" : [ {
    "clientId" : "iam-client",
    "name" : "Imis3 IAM Client",
    "description" : "Imis3 IAM web application",
    "rootUrl" : "${KC_HOSTNAME}",
    "baseUrl" : "${CLIENT_PATH}",
    "secret" : "${CLIENT_SECRET}",
    "redirectUris" : [ "/*" ],
    "webOrigins" : [ "+" ],
