    },
    "permissions" : {
      "view" : [ "admin", "user" ],
      "edit" : [ "admin", "user" ]
    },
    "annotations": {
      "defaultField": "true"
    },
    "validations" : {
      "length" : {
        "min": 3,
        "max" : 255
