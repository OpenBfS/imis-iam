      "view" : [ "user", "admin" ]
    },
    "annotations": {
      "inputType": "html5-tel"
    },
    "validations" : {
      "pattern": {
        "pattern": "(\\(?([\\d \\-)–+/(]+){6,}\\)?([ .\\-–/]?)([\\d]+))",
