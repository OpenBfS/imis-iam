# Keycloak configuration
KC_HTTP_ENABLED=true
KC_HOSTNAME=${PROTOCOLL}://${HOSTNAME}:${PORT}
KC_HOSTNAME_ADMIN=${PROTOCOLL}://${HOSTNAME}:${ADMIN_PORT}

KC_DB_URL
KC_DB_USERNAME
KC_DB_PASSWORD

KC_LOG_CONSOLE_FORMAT=%d{yyyy-MM-dd HH:mm:ss,SSS} %-5p [%c] (%t) %m%n


## Configuration of extension

#Notification recipient email address
IAM_NOTIFICATION_RECIPIENT=imisnotifications@example.test

#Intervals
# Note: Intervals are expected in ISO-8601 duration format.
# Interval at which accounts are checked for inactivity
IAM_MAIL_SCHEDULER_INTERVAL=P1D

# Amount of time before expiry at which a notification about
# inactivity of an account is send to $NOTIFICATION_RECIPIENT
IAM_ACCOUNT_INACITIVITY_WARNING_TIME=P180D

# Time after which an inactiv account expires
IAM_ACCOUNT_EXPIRY_TIME=P365D
