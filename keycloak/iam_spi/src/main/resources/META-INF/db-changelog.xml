<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet author="awoestmann@intevation.de" id="v0.1">
        <!--Create tables-->
        <createTable tableName="mail_list">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false" />
            </column>
        </createTable>
        <createTable tableName="mail_list_user">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="mail_list_id" type="INT">
                <constraints foreignKeyName="fk_mail_list_user_list" references="mail_list(id)" />
            </column>
            <column name="user_id" type="VARCHAR(36)">
                <constraints foreignKeyName="fk_mail_list_user_user" references="user_entity(id)" />
            </column>
        </createTable>
        <createTable tableName="mail_type">
            <column name="id" type="INT">
                <constraints primaryKey="true" />
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false" />
            </column>
        </createTable>
        <createTable tableName="mail">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="send_date" type="timestamp with time zone" defaultValue="now()">
                <constraints nullable="false" />
            </column>
            <column name="expiry_date" type="timestamp with time zone">
            </column>
            <column name="sender" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="text" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="subject" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="publish" type="BOOLEAN">
                <constraints nullable="false" />
            </column>
            <column name="type" type="INT">
                <constraints
                    nullable="false"
                    foreignKeyName="fk_mail_mail_type"
                    references="mail_type(id)"
                />
            </column>
            <column name="receipient" type="INT">
                <constraints
                    nullable="false"
                    foreignKeyName="fk_mail_mail_list"
                    references="mail_list(id)"
                />
            </column>
            <column name="user_id" type="VARCHAR(36)">
                <constraints
                    nullable="false"
                    foreignKeyName="fk_mail_user_entity"
                    references="user_entity(id)"
                />
            </column>
        </createTable>

        <!--Add Constraints-->
        <addUniqueConstraint
            tableName="mail_list_user"
            columnNames="mail_list_id, user_id"
            constraintName="mail_list_user_unique"
        />

        <!--Insert mail type data-->
        <insert tableName="mail_type">
            <column name="id" value="1" />
            <column name="name" value="Einladung" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="2" />
            <column name="name" value="Umfrage" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="3" />
            <column name="name" value="Störung" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="4" />
            <column name="name" value="Wartung" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="5" />
            <column name="name" value="Sprechstunde" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="6" />
            <column name="name" value="Release Note" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="7" />
            <column name="name" value="Soll/Ist-Vergleich" />
        </insert>
        <insert tableName="mail_type">
            <column name="id" value="8" />
            <column name="name" value="Hinweis" />
        </insert>
    </changeSet>
    <changeSet author="awoestmann@intevation.de" id="v0.2">
        <renameColumn
            columnDataType="BOOLEAN"
            tableName="mail"
            oldColumnName="publish"
            newColumnName="archived"
        />
        <update tableName = "mail">
            <column name="archived" value="false" />
            <where>archived='true'</where>
        </update>
    </changeSet>
    <changeSet author="awoestmann@intevation.de" id="v0.3">
        <createTable tableName="institution_category">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false" />
            </column>
        </createTable>
        <createTable tableName="institution">
            <column name="id" type="serial">
                <constraints primaryKey="true" />
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="short_name" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="category_id" type="INT">
                <constraints foreignKeyName="fk_institution_institution_category" references="institution_category(id)" />
            </column>
            <column name="service_building_street" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="service_building_postal_code" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="service_building_location" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="address_street" type="VARCHAR">
            </column>
            <column name="address_postal_code" type="VARCHAR">
            </column>
            <column name="address_location" type="VARCHAR">
            </column>
            <column name="central_phone" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="central_fax" type="VARCHAR">
            </column>
            <column name="central_mail" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="imis_id" type="VARCHAR">
            </column>
            <column name="imis_mail" type="VARCHAR">
            </column>
            <column name="x_coordinate" type="FLOAT">
            </column>
            <column name="y_coordinate" type="FLOAT">
            </column>
            <column name="active" type="BOOLEAN" defaultValue="true">
            </column>
        </createTable>
        <createTable tableName="institution_user">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" />
            </column>
            <column name="institution_id" type="INT">
                <constraints foreignKeyName="fk_institution_user_institution" references="institution(id)" />
            </column>
            <column name="user_id" type="VARCHAR(36)">
                <constraints foreignKeyName="fk_institution_user_user" references="user_entity(id)" />
            </column>
        </createTable>

        <insert tableName="institution_category">
            <column name="name" value="Bundesministerium" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Leitstelle" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Bundesbehörde" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Landesministerium" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Landesdatenzentrale" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Landesmessstelle" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Landesmessstelle REI" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Betreiber KTA" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Aufsichtsbehörde" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Sonstige" />
        </insert>
        <insert tableName="institution_category">
            <column name="name" value="Alle" />
        </insert>
    </changeSet>
    <changeSet author="awoestmann@intevation.de" id="v0.4">
        <createTable tableName="user_position">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="position" type="VARCHAR">
                <constraints nullable="false" />
            </column>
        </createTable>
        <createTable tableName="user_iam_attributes">
            <column name="id" type="VARCHAR">
                <constraints
                    primaryKey="true"
                    foreignKeyName="fk_user_entity_attributes"
                    references="user_entity(id)"
                />
            </column>
            <column name="position_id" type="INT">
                <constraints
                    nullable="false"
                    foreignKeyName="fk_user_attributes_position"
                    references="user_position(id)"
                />
            </column>
            <column name="title" type="VARCHAR">
            </column>
            <column name="phone" type="VARCHAR">
                <constraints nullable="false" />
            </column>
            <column name="mobile" type="VARCHAR">
            </column>
            <column name="fax" type="VARCHAR">
            </column>
            <column name="oe" type="VARCHAR">
            </column>
            <column name="bfs_location" type="VARCHAR">
                <constraints nullable="false" />
            </column>
        </createTable>

        <!--Insert positions-->
        <insert tableName="user_position">
            <column name="position" value="Leiter" />
        </insert>
        <insert tableName="user_position">
            <column name="position" value="Vertreter" />
        </insert>
        <insert tableName="user_position">
            <column name="position" value="Radiologischer Ansprechpartner" />
        </insert>
        <insert tableName="user_position">
            <column name="position" value="Mitarbeiter" />
        </insert>
        <insert tableName="user_position">
            <column name="position" value="IT-Ansprechperson" />
        </insert>
        <insert tableName="user_position">
            <column name="position" value="Störplatz" />
        </insert>
    </changeSet>
</databaseChangeLog>
